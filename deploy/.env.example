BASE_DOMAIN=tailoredpsychology.com.au
LETSENCRYPT_EMAIL=ops@tailoredpsychology.com.au

# On droplet, clone frontend repo beside backend repo.
# Example:
# /opt/clink/tailoredpsychology-backend
# /opt/clink/tailoredpsychology-frontend
FRONTEND_PATH=../../tailoredpsychology-frontend

POSTGRES_DB=clink
POSTGRES_USER=clink
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgres://clink:replace-with-strong-db-password@postgres:5432/clink
AUTH_JWT_SECRET=replace-with-strong-random-secret
AUTH_JWT_EXPIRES_IN=3600
W11H_ENABLE_PURGE_EXECUTION=false
READINESS_REMINDERS_CRON=*/5 * * * *
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
