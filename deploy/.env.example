BASE_DOMAIN=tailoredpsychology.com.au
LETSENCRYPT_EMAIL=ops@tailoredpsychology.com.au

# On droplet, clone frontend repo beside backend repo.
# Example:
# /opt/clink/tailoredpsychology-backend
# /opt/clink/tailoredpsychology-frontend
FRONTEND_PATH=../../tailoredpsychology-frontend

POSTGRES_DB=clink
POSTGRES_USER=clink
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgres://clink:replace-with-strong-db-password@postgres:5432/clink
AUTH_JWT_SECRET=replace-with-strong-random-secret
AUTH_JWT_EXPIRES_IN=3600
# Public site URL for password-reset links (forgot-password emails / devResetUrl)
PUBLIC_APP_URL=https://tailoredpsychology.com.au

# SMTP (required in production for password-reset email delivery)
# Example: transactional provider (SendGrid, Mailgun, SES SMTP relay, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Tailored Psychology <noreply@tailoredpsychology.com.au>
# Shared parent domain: required so `clink_role` applies to both `www` UI and `api` backend.
# Mirror this as COOKIE_DOMAIN on the frontend container too so `/logout` clears the scoped cookie.
COOKIE_DOMAIN=.tailoredpsychology.com.au
# Comma-separated browser origins for credentialed API calls (login/register fetch).
# If unset, defaults are derived from BASE_DOMAIN plus localhost dev ports.
# CORS_ORIGINS=https://tailoredpsychology.com.au,https://www.tailoredpsychology.com.au
W11H_ENABLE_PURGE_EXECUTION=false
READINESS_REMINDERS_CRON=*/5 * * * *

# Twilio Programmable Video (required for in-browser telehealth sessions)
# 1) Twilio Console → Account → API keys & tokens → Create API key
# 2) Copy Account SID (AC...), API Key SID (SK...), and API Key Secret (shown once)
# Do NOT use the Auth Token here — video join tokens require an API Key + Secret pair.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# Stripe Checkout (pay-at-booking)
# Dashboard → Developers → API keys (secret key sk_...)
# Dashboard → Developers → Webhooks → endpoint https://api.<BASE_DOMAIN>/api/payments/stripe/webhook
#   events: checkout.session.completed, checkout.session.expired
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SESSION_FEE_CENTS=22000

# After deploy, apply DB migrations (Wave 19 mood check-ins, etc.):
#   docker compose --env-file .env -f docker-compose.traefik.yml exec api npx prisma migrate deploy
#
# Staging smoke from your laptop (repo root):
#   API_BASE=https://api.tailoredpsychology.com.au/api \
#   WEB_BASE=https://tailoredpsychology.com.au \
#   CORS_ORIGIN=https://tailoredpsychology.com.au \
#   SMOKE_PATIENT_EMAIL=... SMOKE_PATIENT_PASSWORD=... \
#   npm run smoke:wave20
