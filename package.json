{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "description": "Clink backend in NestJS + TypeScript",
  "license": "UNLICENSED",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:clean": "rm -rf dist && nest start --watch",
    "start:prod": "node dist/main",
    "db:migrate:legacy": "node-pg-migrate -m migrations -d DATABASE_URL up",
    "db:migrate": "npm run db:migrate:legacy && node scripts/prisma-migrate-after-legacy.cjs",
    "db:verify": "ts-node scripts/verify-database-schema.ts",
    "db:rollback": "node-pg-migrate -m migrations -d DATABASE_URL down",
    "db:create": "node-pg-migrate -m migrations -d DATABASE_URL create",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "seed:rich-test-data": "ts-node scripts/seed-rich-test-data.ts",
    "seed:staging-qa-users": "ts-node scripts/seed-staging-qa-users.ts",
    "seed:video-session-test": "ts-node scripts/seed-video-session-test.ts",
    "verify:twilio": "ts-node scripts/verify-twilio-video.ts",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:validate": "prisma validate",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.19",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.6.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.6.2",
    "prisma": "^6.19.3",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
